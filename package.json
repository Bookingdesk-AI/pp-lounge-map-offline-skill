{
  "name": "lounge-guru",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:data": "node scripts/build-lounge-data.mjs",
    "build:canonical-data": "node scripts/build-canonical-data.mjs",
    "build:mcp-data": "node scripts/build-mcp-catalog.mjs",
    "build:offline-skill": "node scripts/build-offline-skill.mjs",
    "scrape:sources": "node scripts/scrape-source-snapshots.mjs",
    "build": "npm run build:data && npm run build:canonical-data && npm run build:mcp-data && npm run build:offline-skill && tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --test tests/**/*.test.mjs",
    "skill:export": "node scripts/export-public-skill.mjs",
    "skill:export:offline": "node scripts/export-public-offline-skill.mjs",
    "skill:validate": "skills-ref validate skills/lounge-guru",
    "skill:validate:offline": "skills-ref validate skills/lounge-guru-offline",
    "validate:publish": "node scripts/validate-publish-ready.mjs",
    "validate:publish:offline": "node scripts/validate-publish-ready-offline.mjs",
    "validate:coverage": "node scripts/validate-worldwide-coverage-goal.mjs",
    "validate:cloudflare-auth": "node scripts/validate-worldwide-coverage-goal.mjs --check-cloudflare-auth",
    "validate:json": "node scripts/validate-public-json.mjs",
    "goal:coverage": "node scripts/validate-worldwide-coverage-goal.mjs --strict",
    "intake:cloudflare": "node scripts/run-cloudflare-source-intake-flow.mjs",
    "intake:cloudflare:report": "node scripts/run-cloudflare-source-intake.mjs --report",
    "intake:cloudflare:report:export": "node scripts/run-cloudflare-source-intake.mjs --report --output=public/data/cloudflare-source-intake-report.json",
    "intake:cloudflare:promote": "node scripts/promote-cloudflare-source-intake-report.mjs",
    "intake:evidence": "node scripts/export-cloudflare-source-run-evidence.mjs",
    "db:catalog:sql": "node scripts/export-cloudflare-d1-snapshot.mjs",
    "db:catalog:push": "npm run db:catalog:sql && wrangler d1 execute lounge-guru-catalog --remote --config wrangler.mcp.toml --file .cache/d1/lounge-guru-current-snapshot.sql",
    "db:catalog:smoke": "wrangler d1 execute lounge-guru-catalog --remote --config wrangler.mcp.toml --command=\"SELECT cr.total_records, cr.approved_records, cr.review_records, cr.non_priority_records, vr.status FROM catalog_runs cr LEFT JOIN coverage_validation_runs vr ON vr.catalog_run_id = cr.id ORDER BY cr.created_at DESC LIMIT 1\"",
    "poke:validate": "node scripts/validate-poke-recipe.mjs",
    "poke:bootstrap": "node scripts/print-poke-bootstrap.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "mcp:dev": "wrangler dev --config wrangler.mcp.toml",
    "mcp:deploy": "wrangler deploy --config wrangler.mcp.toml",
    "preview": "vite preview",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "smoke:production": "npm run smoke:deploy -- --base-url=https://loungeguru.desk.travel --min-records=2600 --admin-report=forbidden && npm run smoke:routes -- --base-url=https://loungeguru.desk.travel --min-records=2600 && npm run smoke:ui -- --base-url=https://loungeguru.desk.travel --check-review-queue",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "deploy:web": "wrangler pages deploy dist --project-name uscf-pps-worker --branch main --commit-dirty=true",
    "deploy:mcp": "wrangler deploy --config wrangler.mcp.toml",
    "deploy": "npm run release:prepare && npm run deploy:mcp && npm run deploy:web"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/leaflet": "^1.9.21",
    "@types/papaparse": "^5.5.2",
    "agents": "^0.7.6",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "leaflet.markercluster.freezable": "^1.0.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260316.1",
    "@eslint/js": "^9.39.1",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "skills-ref": "^0.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.69.0"
  }
}
